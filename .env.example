# ===========================================
# Prisma MySQL — pool params explained inline
# ===========================================
# connection_limit: max simultaneous Prisma connections (keep ≤ MySQL max_connections / num_processes)
# pool_timeout: seconds to wait for free connection before error (default 10 → too short, set 30)
# connect_timeout: TCP handshake timeout in seconds
# socket_timeout: max query execution time in seconds
DATABASE_URL="mysql://USER:PASSWORD@127.0.0.1:3306/DATABASE?connection_limit=10&pool_timeout=30&connect_timeout=15&socket_timeout=60"

# ===========================================
# Raw mysql2 pool (legacy) — same DB, separate connection
# ===========================================
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=

# ===========================================
# App
# ===========================================
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# ===========================================
# JWT — use long random strings (minimum 64 characters each)
# ===========================================
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ===========================================
# Cron
# ===========================================
CRON_ENABLED=true

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://127.0.0.1:6379

# ===========================================
# Tech Events Webhook
# ===========================================
TECH_EVENTS_WEBHOOK_ENABLED=false
TECH_EVENTS_WEBHOOK_URL=
TECH_EVENTS_WEBHOOK_SECRET=

# ===========================================
# Google Sheets
# ===========================================
GOOGLE_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# ===========================================
# Google Drive (Evidence Files)
# ===========================================
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=

# ===========================================
# External Scrap Database Configuration
# ===========================================
EXTERNAL_DB_HOST=127.0.0.1
EXTERNAL_DB_PORT=3306
EXTERNAL_DB_USER=
EXTERNAL_DB_PASSWORD=
EXTERNAL_DB_NAME=

# External Table Names (comma-separated)
EXTERNAL_TABLE_NAMES=jatim_tickets,suramadu_tickets,jatengdiy_tickets,balinusra_tickets

# ===========================================
# Ingestion Worker Settings
# ===========================================
INGESTION_ENABLED=true
INGESTION_INTERVAL_MINUTES=5
INGESTION_TIMEOUT_MINUTES=30
INGESTION_LOCK_TTL_SECONDS=1800
INGESTION_CHUNK_SIZE=1000
INGESTION_BATCH_SIZE=500
INGESTION_MAX_RETRIES=3
INGESTION_MAX_CONSECUTIVE_ERRORS=5
INGESTION_RUN_ON_START=true

# ===========================================
# Projection Worker Settings
# ===========================================
PROJECTION_ENABLED=true
PROJECTION_INTERVAL_MINUTES=2
PROJECTION_LOOKBACK_MINUTES=180
PROJECTION_TIMEOUT_MINUTES=30
PROJECTION_LOCK_TTL_SECONDS=1800
PROJECTION_BATCH_SIZE=500
PROJECTION_MAX_CONSECUTIVE_ERRORS=5
PROJECTION_FULL_SCAN_ENABLED=true
PROJECTION_FULL_SCAN_CRON=0 2 * * *
PROJECTION_RUN_ON_START=true
